{
  "version": 4,
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Chip8 Default",
      "description": "Base Chip8 preset",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "SDL_JACK": "OFF",
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_C_STANDARD": "23",
        "BUILD_SHARED_LIBS": "OFF"
      }
    }
  ]
}
